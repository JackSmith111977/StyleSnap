{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "apps/web",
  "extends": "@stylesnap/config-typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/config-eslint/index.ts",
    "../../packages/config-prettier/index.ts"
  ],
  "exclude": ["node_modules"]
}
